# Server
PORT=8080

TRUST_PROXY=true

DATABASE_URL=postgresql://user:password@localhost:5433/database_name

JWT_SECRET=your_long_random_value_min_32_characters
JWT_EXPIRES_IN=24h

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=your_email@gmail.com
REPORT_EMAIL=admin@example.com


ALLOWED_ORIGINS=http://localhost:5173,https://maminkoticek.si,https://test.dev.maminkoticek.si
ALLOW_NO_ORIGIN=true
COOKIE_SAMESITE=none
COOKIE_DOMAIN=.maminkoticek.si
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_POSTS_FOLDER=posts
ENABLE_PUSH_WORKER=true
PUSH_WORKER_POLL_MS=1000
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","token_uri":"https://oauth2.googleapis.com/token"}

